# Copie para .env e ajuste conforme seu ambiente
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# --- MongoDB ---
# Local (MongoDB instalado na máquina ou via winget):
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=chatterbox

# Atlas (sem Docker e sem instalar MongoDB local):
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DATABASE=chatterbox

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# --- OpenAI (obrigatório para respostas reais da IA) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Use "fake" para desenvolver sem chave OpenAI (respostas simuladas)
# AI_PROVIDER=fake
AI_PROVIDER=openai
